# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORGANIZATION=optional_organization_id

# Application Configuration
NODE_ENV=development
PORT=3000
API_PORT=3001
AI_PORT=3002

# Database Configuration (SQLite for development)
DATABASE_URL=sqlite:./data/meetai.db

# File Upload Configuration
MAX_FILE_SIZE=50MB
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/webm,audio/m4a

# Security
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_REAL_TIME_TRANSCRIPTION=true
ENABLE_EMOTION_ANALYSIS=true
ENABLE_TASK_EXTRACTION=true

# External Services (Optional)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_FILES=10

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100